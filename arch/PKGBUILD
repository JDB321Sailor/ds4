# Maintainer: JDB321Sailor <https://github.com/JDB321Sailor>
# Contributor: antirez (upstream author of ds4) <https://github.com/antirez>
#
# Arch / CachyOS package for DS4 — DeepSeek 4 Flash & PRO local inference engine.
# This package is named `dwarfstar4` (DwarfStar 4) and ships the upstream
# binaries unchanged: ds4, ds4-server, ds4-bench, ds4-eval, ds4-agent.
#
# Build target: `make strix-halo` (ROCm / HIP, gfx1151 = Radeon 8060S).
# Source: upstream https://github.com/antirez/ds4 pinned at a known-good
# commit. To upgrade, bump _commit and pkgver and re-run `makepkg -s`.

pkgname=dwarfstar4
_upstream_name=ds4
pkgver=0.r80ebbc3
pkgrel=1
# Pinned upstream commit (antirez/ds4 main @ 2026-06-17). Update together
# with pkgver when bumping.
_commit=80ebbc396aee40eedc1d829222f3362d10fa4c6c
pkgdesc="DeepSeek 4 Flash & PRO local inference engine (ROCm/Strix Halo, gfx1151)"
arch=('x86_64')
url="https://github.com/antirez/ds4"
license=('MIT')

# Runtime: HIP + the BLAS / WMMA libs the Strix Halo backend links against.
depends=(
  'rocm-hip-runtime'
  'rocblas'
  'hipblas'
  'hipblaslt'
  'rocwmma'
)

# Build: hipcc + HIP/ROCm headers (rocm-hip-sdk provides hipcc), and the
# usual base-devel chain. `git` is needed by the VCS source line.
makedepends=(
  'git'
  'make'
  'gcc'
  'rocm-hip-sdk'
  'rocm-llvm'
  'rocwmma'
  'rocblas'
  'hipblas'
  'hipblaslt'
)

# Optional helpers for runtime sanity / monitoring.
optdepends=(
  'rocminfo: query ROCm devices (rocminfo | grep gfx1151)'
  'rocm-smi-lib: rocm-smi runtime GPU monitoring'
)

# Five upstream binaries — declare them so `pacman -Qi` shows what is shipped.
provides=(
  'ds4'
  'ds4-server'
  'ds4-bench'
  'ds4-eval'
  'ds4-agent'
)
conflicts=("${provides[@]}")

options=(!strip !lto)

source=(
  "${_upstream_name}::git+https://github.com/antirez/ds4.git#commit=${_commit}"
)
sha256sums=('SKIP')

pkgver() {
  cd "${srcdir}/${_upstream_name}"
  # 0.r<short-sha>; bump the leading "0." only when upstream cuts a real version.
  printf '0.r%s' "$(git rev-parse --short=7 HEAD)"
}

build() {
  cd "${srcdir}/${_upstream_name}"

  # Use the system hipcc (Arch installs to /opt/rocm/bin/hipcc) and the
  # Strix Halo offload arch. These match the Makefile defaults, but we set
  # them explicitly so the build is reproducible regardless of PATH order.
  export HIPCC="${HIPCC:-/opt/rocm/bin/hipcc}"
  export ROCM_ARCH="${ROCM_ARCH:-gfx1151}"

  # Drop -march=native so the resulting binaries are usable on any Zen 5
  # Strix Halo box, not just the build host. The Makefile defaults
  # NATIVE_CPU_FLAG to -march=native; override it.
  export NATIVE_CPU_FLAG="-march=x86-64-v3"

  # Build the ROCm / Strix Halo target. This produces ds4, ds4-server,
  # ds4-bench, ds4-eval, ds4-agent in the source tree.
  make strix-halo -j"$(nproc)"
}

package() {
  cd "${srcdir}/${_upstream_name}"

  # Binaries.
  install -Dm755 ds4         "${pkgdir}/usr/bin/ds4"
  install -Dm755 ds4-server  "${pkgdir}/usr/bin/ds4-server"
  install -Dm755 ds4-bench   "${pkgdir}/usr/bin/ds4-bench"
  install -Dm755 ds4-eval    "${pkgdir}/usr/bin/ds4-eval"
  install -Dm755 ds4-agent   "${pkgdir}/usr/bin/ds4-agent"

  # License (required by pacman QA for non-common licenses, and good practice anyway).
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"

  # Documentation — keep the upstream Markdown so users have it under
  # /usr/share/doc/dwarfstar4/ after install.
  install -Dm644 README.md      "${pkgdir}/usr/share/doc/${pkgname}/README.md"
  install -Dm644 STRIXHALO.md   "${pkgdir}/usr/share/doc/${pkgname}/STRIXHALO.md"
  install -Dm644 MODEL_CARD.md  "${pkgdir}/usr/share/doc/${pkgname}/MODEL_CARD.md"

  # The model-download helper is handy to ship alongside the binaries.
  install -Dm755 download_model.sh \
    "${pkgdir}/usr/share/${pkgname}/download_model.sh"
}
